<!--
    Left list view.

    SELECTION:
      SelectedModel TwoWay — single binding handles both directions.
      User click  → control pushes raw model out → VM.SelectedModel → SelectionService
      External set → SelectionService → VM.SelectedModel → binding → control inbound →
                     control finds wrapper, jumps page, sets ListBox.SelectedItem

    SELECTION HIGHLIGHT:
      Driven by the ListBoxItem :selected pseudo-class. No IsSelected property needed
      on the wrapper VM. Style the AnimatedItemContainer:selected selector in your theme.
-->
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:YourApp.Controls"
             xmlns:vm="clr-namespace:YourApp.Examples"
             x:Class="YourApp.Views.LeftListView"
             x:DataType="vm:LeftListViewModel">

    <UserControl.Styles>
        <!-- Selection highlight — targets the Border inside the item template
             when the containing AnimatedItemContainer is in the selected state. -->
        <Style Selector="controls|AnimatedItemContainer:selected Border.ItemRoot">
            <Setter Property="Background" Value="#3a5a8a"/>
        </Style>
    </UserControl.Styles>

    <StackPanel Spacing="8">

        <controls:OrderedAnimatedListBox x:Name="ListBox"
            FullItems="{Binding Items}"
            Coordinator="{Binding Coordinator,
                          RelativeSource={RelativeSource AncestorType=UserControl}}"
            TransferCommand="{Binding TransferCommand,
                              RelativeSource={RelativeSource AncestorType=UserControl}}"
            SelectedModel="{Binding SelectedModel, Mode=TwoWay}"
            CurrentPage="{Binding CurrentPage, Mode=TwoWay}"
            EntryDirection="Right"
            ExitDirection="Right"
            AnimationDuration="0:0:0.2"
            PageSize="4"
            Width="240"
            ClipToBounds="True">

            <controls:OrderedAnimatedListBox.ItemTemplate>
                <DataTemplate x:DataType="vm:LeftItemVm">
                    <!--
                        Give the Border the "ItemRoot" class so the :selected style above
                        can target it specifically without affecting other Borders in the template.
                    -->
                    <Border Classes="ItemRoot"
                            Padding="12,8"
                            Margin="0,2"
                            CornerRadius="4"
                            Background="#1e1e1e">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0"
                                       Text="{Binding Name}"
                                       Foreground="White"
                                       VerticalAlignment="Center"/>
                            <Button Grid.Column="1"
                                    Content="→"
                                    Command="{Binding $parent[controls:OrderedAnimatedListBox].TransferCommand}"
                                    CommandParameter="{Binding}" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </controls:OrderedAnimatedListBox.ItemTemplate>

        </controls:OrderedAnimatedListBox>

        <!-- Page controls -->
        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
            <Button Content="◀" Command="{Binding #ListBox.PreviousPageCommand}" />
            <TextBlock VerticalAlignment="Center">
                <Run Text="{Binding #ListBox.CurrentPage}"/>
                <Run Text=" / "/>
                <Run Text="{Binding #ListBox.PageCount}"/>
            </TextBlock>
            <Button Content="▶" Command="{Binding #ListBox.NextPageCommand}" />
        </StackPanel>

    </StackPanel>

</UserControl>
